# ── Upstream LLM Provider ────────────────────────────────────────────
UPSTREAM_BASE_URL=https://api.llmzone.net/v1
UPSTREAM_API_KEY=sk-llmzone-your-key-here
UPSTREAM_TIMEOUT=300

# ── Key Rotation (comma-separated list for multi-key rotation) ──────
# If set, overrides UPSTREAM_API_KEY. Keys rotate round-robin.
# When a key hits rate limits, it's blacklisted for KEY_COOLDOWN_SECONDS.
# UPSTREAM_API_KEYS=sk-llmzone-key1,sk-llmzone-key2,sk-llmzone-key3
KEY_COOLDOWN_SECONDS=7200
# ENABLE_KEY_ROTATION=true  # auto-enabled when multiple keys present

# ── Proxy Server ────────────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_PORT=8080

# ── Feature Flags ───────────────────────────────────────────────────
ENABLE_TOOL_FIXER=true
ENABLE_RESPONSE_VALIDATOR=true
ENABLE_REQUEST_LOGGING=false

# ── Logging ─────────────────────────────────────────────────────────
LOG_DIR=./logs
LOG_LEVEL=WARNING
